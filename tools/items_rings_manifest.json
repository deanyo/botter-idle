  "notes": "Source of truth for the item editor (ring tab). DCSS base types from item-prop-enum.h jewellery_type enum: RING_PROTECTION/STRENGTH/SLAYING/EVASION/STEALTH/DEXTERITY/INTELLIGENCE/MAGICAL_POWER/WILLPOWER + protection-from-fire/cold/poison resistance and ring of flight. Two ring slots planned (ring1, ring2). Stats lean small but stack \u2014 rings are the affix-spreader slot.",
  "base_types": {
    "ring_protection": {
      "label": "Ring of Protection",
      "category": "ring",
      "dcss_base": "RING_PROTECTION",
      "flavor": "+DEF. Defensive build cornerstone."
    },
    "ring_strength": {
      "label": "Ring of Strength",
      "category": "ring",
      "dcss_base": "RING_STRENGTH",
      "flavor": "+ATK. Direct damage scaler."
    },
    "ring_slaying": {
      "label": "Ring of Slaying",
      "category": "ring",
      "dcss_base": "RING_SLAYING",
      "flavor": "+ATK and accuracy. The hunter's classic."
    },
    "ring_evasion": {
      "label": "Ring of Evasion",
      "category": "ring",
      "dcss_base": "RING_EVASION",
      "flavor": "+DEF via dodge. Future: dodge mechanic."
    },
    "ring_dexterity": {
      "label": "Ring of Dexterity",
      "category": "ring",
      "dcss_base": "RING_DEXTERITY",
      "flavor": "+Crit/+Haste. Speed-flavored ring."
    },
    "ring_regen": {
      "label": "Ring of Regeneration",
      "category": "ring",
      "dcss_base": "RING_REGENERATION",
      "flavor": "+HP regen. Sustained build."
    },
    "ring_fire": {
      "label": "Ring of Fire Res",
      "category": "ring",
      "dcss_base": "RING_PROTECTION_FROM_FIRE",
      "flavor": "Fire resistance. Strong vs Forge."
    },
    "ring_cold": {
      "label": "Ring of Cold Res",
      "category": "ring",
      "dcss_base": "RING_PROTECTION_FROM_COLD",
      "flavor": "Cold resistance. Strong vs Glacier."
    },
    "ring_poison": {
      "label": "Ring of Poison Res",
      "category": "ring",
      "dcss_base": "RING_POISON_RESISTANCE",
      "flavor": "Poison resistance. Strong vs Swamp/Spider."
    },
    "ring_willpower": {
      "label": "Ring of Willpower",
      "category": "ring",
      "dcss_base": "RING_WILLPOWER",
      "flavor": "Magic resistance. Strong vs casters."
    },
    "ring_stealth": {
      "label": "Ring of Stealth",
      "category": "ring",
      "dcss_base": "RING_STEALTH",
      "flavor": "Lower aggro range. Avoid swarms."
    },
    "ring_magic": {
      "label": "Ring of Magical Power",
      "category": "ring",
      "dcss_base": "RING_MAGICAL_POWER",
      "flavor": "End-game caster ring. Future mechanic-heavy."
    },
    "ring_flight": {
      "label": "Ring of Flight",
      "category": "ring",
      "dcss_base": "RING_FLIGHT",
      "flavor": "Ignore terrain hazards."
    }
