# DCSS source: GPLv2+ research-only clone (132 MB). Don't ship — would
# infect the project with GPL obligations on game logic.
dcss-source/

# Note: dcss/ (the CC0 tile pack, ~35 MB) IS tracked. The authoring
# portal hosted on GitHub Pages reads tiles from `dcss/...` for the
# atlas viewer + item editor. CC0 1.0 Universal; no attribution
# required, but credited in NOTICE.md and the in-game Credits screen
# (main menu → Credits) per the original DCSS team's request.

# macOS metadata
.DS_Store
**/.DS_Store

# Godot build artifacts and editor cache
project/.godot/
project/.import/
project/export.cfg
# Note: project/export_presets.cfg IS tracked. It carries the
# load-bearing `exclude_filter="data/vaults/*.json,..."` entry that
# keeps GPL-derived vault content out of the web build (see
# NOTICE.md). Gitignoring would mean a fresh checkout silently
# re-ships those vaults. tools/deploy_web.sh additionally asserts
# the filter is present at deploy time as defense in depth.
project/exports/
# Itch.io / web build outputs — regenerated per release, not tracked.
dist/
*.translation

# IDE / editor scratch
.vscode/
.idea/
*.swp
*.swo

# Python build dirs from atlas builder
__pycache__/
*.pyc

# Local-only debug + grind scratch
/tmp/
# In-repo logs (timestamped per-run; persistent for diff/grep but not pushed)
logs/
# Local screenshot copies (canonical lives in user://debug_screenshots/)
screenshots/
# analyze_spell_dps_curve.py output (regenerated on every run)
tools/plots/

# Project-local Claude config (only commit settings.json shared cfg if you want)
.claude/settings.local.json
